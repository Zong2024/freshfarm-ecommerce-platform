{
  "name": "freshfarm-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "seed": "pnpm --filter @freshfarm/api seed"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5",
    "prettier": "^3.8.1"
  }
}